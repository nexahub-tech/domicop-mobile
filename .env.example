# SECRET keys (sk_test_*) should only be used server-side
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
EXPO_PUBLIC_PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here